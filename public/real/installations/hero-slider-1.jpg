<script>
	function loginModal(){
		const modalLogin = new bootstrap.Modal('#modalLogin', {
		  keyboard: false
		});
		
		modalLogin.toggle();
	}
	
	function login() {
		var loginErrorMessage = document.getElementById("loginErrorMessage");
		loginErrorMessage.innerHTML = '';
		loginErrorMessage.style.display =  'none';
		a = document.getElementById("userEmail").value; 
		b = document.getElementById("userPass").value;
		if(a && b){
			$.ajax({
				type: 'POST',
				url: 'https://www.adoreenergysystems.com/api/',
				data: {login: true,user: a,pass: b},
				success: function (response) {
					if (response.code === '200') {
						window.location = 'https://www.adoreenergysystems.com';
					} else if(response.code === '201'){
						loginErrorMessage.innerHTML = '<p>Your account is with status <span class="btn btn-success w-auto p-1">pending</span></p>Please check your email for confirmation.';
						loginErrorMessage.style.display =  'block';
					} else if(response.code === '202'){
						loginErrorMessage.innerHTML = '<p>Your account is <span class="btn btn-success w-auto p-1">Disabled</span></p>Please contact our support for details.';
						loginErrorMessage.style.display =  'block';
					} else {
						loginErrorMessage.innerHTML = response.message + '<br>Wrong email or password';
						loginErrorMessage.style.display =  'block';
					}
				},
				error: function (error) {
					console.error(error);
				}
			});
		} else {
			loginErrorMessage.style.display =  'block';
		}
	}

	function logout() {
		$.ajax({
			type: 'POST',
			url: 'https://www.adoreenergysystems.com/api/',
			data: {logut: true},
			success: function (response) {
			location.reload();
			}
		});
	}
	
	function nav(a){
		window.location = 'https://www.adoreenergysystems.com/'+a+'/';
	}
	
</script>
